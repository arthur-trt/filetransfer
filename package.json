{
  "name": "filetransfer",
  "version": "1.2.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@prisma/client": "^6.2.1",
    "@react-email/components": "^0.0.32",
    "@react-email/render": "^1.0.4",
    "client-zip": "^2.4.5",
    "hash-wasm": "^4.12.0",
    "next": "^15.5.15",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^6.9.16",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.0",
    "happy-dom": "^15.11.7",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
