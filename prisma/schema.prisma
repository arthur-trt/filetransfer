generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transfer {
  id            String   @id
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  revoked       Boolean  @default(false)
  completed     Boolean  @default(false)

  fileCount     Int
  totalBytes    BigInt

  pwSalt        Bytes?
  pwWrappedKey  Bytes?
  pwKdfParams   Json?

  downloadCap   Int?
  downloadCount Int      @default(0)

  senderIp      String?
  hasPassword   Boolean  @default(false)
  emailedTo     Boolean  @default(false)

  r2Keys        String[] @default([])
  multipartIds  Json?

  pendingRecipients String[] @default([])
  pendingMessage    String?

  @@index([expiresAt])
  @@index([revoked, expiresAt])
}
